# AI Agent Platform Configuration
# All variables use the AI_AGENT_ prefix to match the pydantic-settings env_prefix.

# LLM Provider
AI_AGENT_LLM_PRIMARY_PROVIDER=deepseek
AI_AGENT_LLM_PRIMARY_MODEL=deepseek-v3
AI_AGENT_LLM_PRIMARY_TEMPERATURE=0.1
AI_AGENT_LLM_PRIMARY_MAX_TOKENS=4096
AI_AGENT_LLM_FALLBACK_PROVIDER=openai
AI_AGENT_LLM_FALLBACK_MODEL=gpt-4o

# API Keys (configure per provider)
AI_AGENT_DEEPSEEK_API_KEY=
AI_AGENT_OPENAI_API_KEY=
AI_AGENT_ANTHROPIC_API_KEY=
AI_AGENT_ZHIPU_API_KEY=

# Gateway
AI_AGENT_GATEWAY_HOST=0.0.0.0
AI_AGENT_GATEWAY_PORT=8000
AI_AGENT_GATEWAY_WORKERS=4

# Redis
AI_AGENT_REDIS_URL=redis://localhost:6379/0

# PostgreSQL (Phase 2)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_agent_platform
PG_USER=ai_agent
PG_PASSWORD=

# JWT Auth
AI_AGENT_JWT_SECRET=change-this-in-production
AI_AGENT_JWT_ALGORITHM=HS256
AI_AGENT_JWT_EXPIRE_MINUTES=480

# API Key Auth
API_KEY_HEADER=X-API-Key

# Memory
AI_AGENT_MEMORY_BASE_DIR=~/.ai-agent-platform/workspace

# Sandbox
AI_AGENT_SANDBOX_ENABLED=true
AI_AGENT_SANDBOX_BACKEND=agentscope_remote
AI_AGENT_SANDBOX_FAIL_CLOSED=true
AI_AGENT_SANDBOX_BASE_URL=http://sandbox-runtime:8000
AI_AGENT_SANDBOX_BEARER_TOKEN=
AI_AGENT_SANDBOX_NETWORK_DEFAULT=deny
AI_AGENT_SANDBOX_SESSION_TTL_SECONDS=3600
AI_AGENT_SANDBOX_DOCKER_IMAGE=ai-agent-sandbox:latest
AI_AGENT_SANDBOX_TIMEOUT_SECONDS=30
AI_AGENT_SANDBOX_MAX_MEMORY=256m

# Production
AI_AGENT_SERVE_STATIC=false
AI_AGENT_STATIC_DIR=web/dist
AI_AGENT_GATEWAY_WORKERS=4

# Logging
AI_AGENT_LOG_LEVEL=INFO
